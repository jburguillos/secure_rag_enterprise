# Runtime mode
APP_MODE=prod
ALLOW_PUBLIC_LLM=false
ALLOW_OUTBOUND=false
ENABLE_OCR=false
ENABLE_RERANK=false

# API and UI
API_HOST=0.0.0.0
API_PORT=8000
UI_PORT=8501
UI_QUERY_TIMEOUT_SEC=300
UI_TOKEN_REFRESH_SKEW_SEC=30
KEYCLOAK_CLIENT_ID=secure-rag-api
KEYCLOAK_TOKEN_URL=http://keycloak:8080/realms/secure-rag/protocol/openid-connect/token
UI_DEFAULT_USERNAME=
UI_DEFAULT_PASSWORD=
# Datastores
QDRANT_URL=http://qdrant:6333
QDRANT_TEXT_COLLECTION=text_nodes
QDRANT_IMAGE_COLLECTION=image_nodes
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=secure_rag
POSTGRES_USER=secure_rag
POSTGRES_PASSWORD=secure_rag
DATABASE_URL=postgresql+psycopg://secure_rag:secure_rag@postgres:5432/secure_rag

# LLM/Embedding providers
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_BATCH_SIZE=16
VLM_ROUTER=disabled
VLM_ROUTER_MAX_IMAGES=6
PUBLIC_LLM_BASE_URL=
PUBLIC_LLM_API_KEY=

# Google Drive ingestion
DRIVE_AUTH_MODE=oauth
GOOGLE_CREDENTIALS_PATH=/data/google/credentials.json
GOOGLE_TOKEN_PATH=/data/google/token.json
GOOGLE_SERVICE_ACCOUNT_JSON=
DRIVE_FOLDER_ID=
DRIVE_GROUP_MAP_JSON={}
GOOGLE_DRIVE_USE_READER=false

# Optional verification identity (for scripts/verify_phase1.ps1)
VERIFY_DRIVE_EMAIL=
VERIFY_DRIVE_DOMAIN=
VERIFY_DRIVE_GROUPS=

# AuthN/AuthZ
AUTH_ENABLED=false
KEYCLOAK_ISSUER=http://keycloak:8080/realms/secure-rag
KEYCLOAK_ISSUER_ALIASES=http://localhost:8080/realms/secure-rag
KEYCLOAK_AUDIENCE=secure-rag-api
ADMIN_AUTHORIZED_GROUPS=admin
KEYCLOAK_ADMIN_URL=http://keycloak:8080
KEYCLOAK_REALM=secure-rag
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
OPA_URL=http://opa:8181
OPA_POLICY_PATH=/v1/data/secure_rag/authz/allow
OPA_FAIL_CLOSED=true

# Retrieval and generation
TOP_K_DENSE=8
TOP_K_BM25=8
TOP_K_FUSED=8
RETRIEVAL_CANDIDATE_MULTIPLIER=4
RETRIEVAL_CANDIDATE_MAX=80
RETRIEVAL_DOC_DIVERSITY_MAX_CHUNKS=2
RERANK_TOP_CANDIDATES=40
MAX_CONTEXT_CHARS=12000
GENERATION_MAX_EVIDENCE_NODES=4
GENERATION_DOC_DIVERSITY_MAX_CHUNKS=1
SUMMARIZE_MAP_MAX_DOCS=6
SUMMARIZE_MAP_CHARS_PER_DOC=700
REQUIRE_CITATIONS=true
MIN_CITATIONS=1
REFUSAL_TEXT=I do not have enough authorized evidence to answer that.
DOMAIN_CONTEXT_HINT=The indexed corpus often simulates an internal venture capital fund operating model, including fundraising, LP commitments, capital calls, due diligence, portfolio management, market research, legal/compliance, and board reporting workflows.

# Paths
LOCAL_INGEST_ROOT=./tests/data/sample_docs
LOCAL_ACL_SIDECAR=./tests/data/sample_docs/acl_map.yaml
PDF_IMAGE_ROOT=./artifacts/pdf_images
AUDIT_RAW_QUERY=false

